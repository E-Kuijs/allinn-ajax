{
  "expo": {
    "name": "ALL-INN AJAX",
    "slug": "all-inn-ajax",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/logo-ajax-square.png",
    "userInterfaceStyle": "light",
    "scheme": "ajaxnieuws",
    "splash": {
      "image": "./assets/images/logo-ajax.png",
      "resizeMode": "contain",
      "backgroundColor": "#d2001c"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.allinmedia.allinajax",
      "buildNumber": "10",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-ajax-square.png",
        "backgroundColor": "#d2001c"
      },
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.allinmedia.allinajax",
      "versionCode": 10,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "ALL-INN AJAX wil toegang tot je foto's.",
          "cameraPermission": "ALL-INN AJAX wil toegang tot je camera."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "ALL-INN AJAX wil toegang tot je camera om QR-codes te scannen."
        }
      ],
      "expo-notifications",
      "expo-speech-recognition",
      "expo-audio",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "02ad4d91-5fe2-443f-be18-02f22c6b19e7"
      },
      "router": {}
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/02ad4d91-5fe2-443f-be18-02f22c6b19e7"
    }
  }
}
